# Renomeie para .env e preencha com seus dados reais
# NUNCA comite o .env no git

# Discord
DISCORD_TOKEN=SEU_TOKEN_AQUI

# Dashboard
DASHBOARD_SECRET_KEY=troque_por_uma_chave_segura_aleatoria
DASHBOARD_PORT=5000
DASHBOARD_HOST=0.0.0.0

# Google Sheets (opcional, se usar)
GOOGLE_SHEETS_CREDENTIALS=credentials/credentials.json
GOOGLE_SHEETS_SPREADSHEET=Nome da Planilha
GOOGLE_SHEETS_WORKSHEET=Nome da Worksheet

# Modo
DEBUG=false

# Canal Discord para alertas do bot (opcional)
# Se definido, o bot envia mensagem aqui quando reconecta após queda
ALERT_CHANNEL_ID=

# Credenciais do dashboard
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=troque_por_senha_forte
